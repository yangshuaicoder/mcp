{
    "name": "yangshuaicoder/mcp",
    "description": "MCP管理后台",
    "type": "project",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.0.0",
        "yiisoft/yii2": "~2.0.45"
    },
    "require-dev": {
        "yiisoft/yii2-debug": "~2.1.0",
        "yiisoft/yii2-gii": "~2.2.0"
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        },
        "process-timeout": 1800,
        "fxp-asset": {
            "enabled": false
        }
    },
    "autoload": {
        "psr-4": {
            "app\\": ""
        }
    },
    "repositories": [
        {
            "name": "packagist",
            "type": "composer",
            "url": "https://mirrors.cloud.tencent.com/composer/"
        },
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ]
}
